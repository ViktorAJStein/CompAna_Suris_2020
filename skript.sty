\usepackage{titletoc}
\contentsmargin{0cm}

\titlecontents{section}[0pc]
{\addvspace{30pt}}%
{\begin{tikzpicture}[remember picture, overlay]%
\draw[fill=mycol\thecontentslabel!50!white,draw=mycol\thecontentslabel] (-4,-.2) rectangle (-0.5,.5);%
\pgftext[left,x=-1.1cm,y=0.2cm]{\color{white}\Large\sc\bfseries \thecontentslabel};%
\end{tikzpicture}\color{black}\Large\sc\bfseries}
{\color{black}\large\sc\bfseries}
{\color{black}\;\titlerule\;\large\sc\bfseries Page \thecontentspage
\begin{tikzpicture}[remember picture, overlay]
\draw[fill=doc!25,draw=mycol\thecontentslabel] (2pt,0) rectangle (6,0.1pt);
\end{tikzpicture}}%

\titlecontents{subsection}[2.4pc]
{\addvspace{1pt}}
{\contentslabel[\thecontentslabel]{2.4pc}}
{}
{\dotfill\small \thecontentspage}
[]
\titlecontents{subsubsection}[5pc]
{\addvspace{1pt}}
{\contentslabel[\thecontentslabel]{2.4pc}}
{}
{\dotfill\small \thecontentspage}
[]
\makeatletter

\renewcommand{\tableofcontents}{%
\section*{%
\vspace*{-20\p@}%
\begin{tikzpicture}[remember picture, overlay]%
\pgftext[right,x=15cm,y=0.2cm]{\color{mycol1}\Huge\sc\bfseries    
\contentsname};%
\draw[fill=mycol1,draw=mycol1] (13,-.75) rectangle (20,1);%
\clip (13,-.75) rectangle (20,1);
\pgftext[right,x=15cm,y=0.2cm]{\color{white}\Huge\sc\bfseries 
\contentsname};%
\end{tikzpicture}}%
\@starttoc{toc}}
\makeatother

